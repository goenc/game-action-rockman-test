[gd_scene format=4]

[ext_resource type="Script" path="res://debug/panels/DebugInputPanel.gd" id="1_panel_script"]

[node name="DebugInputPanel" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
script = ExtResource("1_panel_script")

[node name="MarginContainer" type="MarginContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 10

[node name="CurrentInputTitleLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "現在入力"

[node name="CurrentInputLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
mouse_filter = 2
theme_override_font_sizes/font_size = 30
text = "入力 : なし"
autowrap_mode = 3
clip_text = false

[node name="PressCountLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "同時押し数 : 0"

[node name="PressedKeysLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "押下中キー : なし"
autowrap_mode = 3
